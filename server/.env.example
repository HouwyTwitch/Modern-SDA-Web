# Copy to .env (or export) for production. In dev these are auto-generated and
# persisted to gitignored files.

# 32-byte hex secrets — generate with: python -c "import secrets;print(secrets.token_hex(32))"
SERVER_MASTER_KEY=
JWT_SECRET=

# Optional RSA private key (PEM) for the encrypted channel. Auto-generated if unset.
# RSA_PRIVATE_KEY_PEM=

# Database (async SQLAlchemy URL). Defaults to a local SQLite file.
# DATABASE_URL=sqlite+aiosqlite:///./modern_sda.db

# Comma-separated allowed origins for CORS (your frontend origin).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Token + unlock lifetimes (minutes).
JWT_TTL_MINUTES=720
UNLOCK_TTL_MINUTES=60
