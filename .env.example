# Used by docker-compose (copy to ".env"). Optional for local `run` scripts.
#
# Generate strong 32-byte hex secrets:
#   python -c "import secrets;print(secrets.token_hex(32))"
#
# If left blank, keys are auto-generated and persisted in the Docker data volume.
SERVER_MASTER_KEY=
JWT_SECRET=

# Origin(s) the UI is served from (same-origin in single-server mode).
CORS_ORIGINS=http://localhost:8000
